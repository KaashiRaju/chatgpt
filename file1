package com.repository;

import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import com.entity.Article;

@Repository   // ✅ Required annotation
public interface ArticleRepository extends JpaRepository<Article, Integer> {

    // ✅ View articles by tag
    List<Article> findByTag(String tag);

    // ✅ View articles with likes >= given value
    List<Article> findByLikesCountGreaterThanEqual(int likesCount);

    // ✅ View articles by author and article type
    List<Article> findByAuthorAndArticleType(String author, String articleType);
}
